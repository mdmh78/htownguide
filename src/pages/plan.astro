---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Plan Your Houston Trip — AI Itinerary Builder | HtownGuide"
  description="Tell us your dates and interests — we'll build you a custom 1-3 day Houston itinerary with neighborhoods, restaurants, hotels, and attractions."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-24 text-center">
    <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-4">Coming soon</span>
    <h1 class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl tracking-tight leading-tight mb-8 text-balance">
      AI-built Houston itineraries.
    </h1>
    <p class="text-lg text-[color:var(--color-ink-soft)] mb-10 max-w-xl mx-auto text-pretty">
      Tell us your dates, neighborhood, budget, and what you're into — we'll generate a complete 1–3 day Houston itinerary with restaurants, hotels, and activities matched to you.
    </p>
    <p class="text-sm text-[color:var(--color-ink-soft)]/70 mb-8 max-w-md mx-auto">
      Currently in development. In the meantime, browse our hand-picked guides:
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/neighborhoods" class="inline-flex items-center gap-2 border border-[color:var(--color-ink)]/20 px-5 py-3 text-sm font-medium hover:bg-[color:var(--color-paper)] transition-colors">Neighborhoods</a>
      <a href="/hotels" class="inline-flex items-center gap-2 border border-[color:var(--color-ink)]/20 px-5 py-3 text-sm font-medium hover:bg-[color:var(--color-paper)] transition-colors">Hotels</a>
      <a href="/restaurants" class="inline-flex items-center gap-2 border border-[color:var(--color-ink)]/20 px-5 py-3 text-sm font-medium hover:bg-[color:var(--color-paper)] transition-colors">Restaurants</a>
      <a href="/things-to-do" class="inline-flex items-center gap-2 border border-[color:var(--color-ink)]/20 px-5 py-3 text-sm font-medium hover:bg-[color:var(--color-paper)] transition-colors">Things to Do</a>
    </div>
  </section>
</BaseLayout>
