---
import BaseLayout from "../layouts/BaseLayout.astro";

const featured = [
  {
    name: "Montrose",
    tag: "Art & nightlife",
    desc: "Tree-lined streets, vintage bungalows, the Menil Collection, and the city's most interesting bars and queer history.",
    href: "/neighborhoods/montrose",
    img: "https://images.unsplash.com/photo-1561214115-f2f134cc4912?w=900&q=80&auto=format&fit=crop",
    color: "bg-pink-500",
  },
  {
    name: "The Heights",
    tag: "Historic walkable",
    desc: "Restored Victorians, indie boutiques on 19th Street, and patio bars that feel like a small town inside a big city.",
    href: "/neighborhoods/heights",
    img: "https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=900&q=80&auto=format&fit=crop",
    color: "bg-teal-500",
  },
  {
    name: "Downtown",
    tag: "Stadiums & sky bars",
    desc: "Where the Astros, Rockets, and Texans play, plus rooftop cocktails, theaters, and tunnel-level lunch spots.",
    href: "/neighborhoods/downtown",
    img: "https://images.unsplash.com/photo-1667754248024-e1e03e60eb72?w=900&q=80&auto=format&fit=crop",
    color: "bg-amber-500",
  },
  {
    name: "Museum District",
    tag: "Culture core",
    desc: "Nineteen museums in a one-and-a-half-mile circle. Most cost nothing. The MFAH alone takes a full afternoon.",
    href: "/neighborhoods/museum-district",
    img: "https://images.unsplash.com/photo-1486718448742-163732cd1544?w=900&q=80&auto=format&fit=crop",
    color: "bg-blue-500",
  },
];

const sections = [
  {
    kicker: "Where to stay",
    title: "Hotels, picked the way locals would.",
    body: "From the Hotel Icon downtown to boutique stays in the Heights and budget motels near NRG — sorted by neighborhood, vibe, and what you actually want to do.",
    cta: "Browse hotels",
    href: "/hotels",
    img: "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1000&q=80&auto=format&fit=crop",
  },
  {
    kicker: "Where to eat",
    title: "Tex-Mex, Viet-Cajun, BBQ, and the new wave.",
    body: "Houston is the most diverse food city in America. We sort it by the night you're having — date, family, late, fancy, or strictly meat. Start with our Houston BBQ deep-dive — the city has quietly become the best BBQ town in Texas.",
    cta: "Read the BBQ guide",
    href: "/houston-bbq",
    img: "https://images.unsplash.com/photo-1607013251379-e6eecfffe234?w=1000&q=80&auto=format&fit=crop",
  },
  {
    kicker: "What to do",
    title: "Beyond the obvious.",
    body: "Yes, Space Center and NASA. But also: bayou kayaking, the underground tunnels, free museum days, the rodeo (in season), and the bars locals actually go to.",
    cta: "Things to do",
    href: "/things-to-do",
    img: "https://images.unsplash.com/photo-1574629810360-7efbbe195018?w=1000&q=80&auto=format&fit=crop",
  },
];

const vibeGallery = [
  { src: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=600&q=80&auto=format&fit=crop", caption: "Tex-Mex on every corner" },
  { src: "https://images.unsplash.com/photo-1582878826629-29b7ad1cdc43?w=600&q=80&auto=format&fit=crop", caption: "Vietnamese pho in Bellaire" },
  { src: "https://images.unsplash.com/photo-1561214115-f2f134cc4912?w=600&q=80&auto=format&fit=crop", caption: "Mural city — Montrose" },
  { src: "https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&q=80&auto=format&fit=crop", caption: "Rooftop cocktails" },
  { src: "https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=600&q=80&auto=format&fit=crop", caption: "Live music nights" },
  { src: "https://images.unsplash.com/photo-1551958219-acbc608c6377?w=600&q=80&auto=format&fit=crop", caption: "World Cup summer" },
  { src: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80&auto=format&fit=crop", caption: "Fine-dining capital" },
  { src: "https://images.unsplash.com/photo-1444723121867-7a241cacace9?w=600&q=80&auto=format&fit=crop", caption: "Sunset skyline" },
];
---

<BaseLayout
  title="HtownGuide — The independent guide to Houston, Texas"
  description="An evergreen, locally-edited guide to Houston: where to stay, eat, drink, and explore. Honest takes, neighborhood-first, no corporate fluff."
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-houston-glow">
    <!-- Decorative color blobs -->
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-[color:var(--color-clay)] opacity-15 blur-3xl"></div>
    <div class="absolute top-1/2 -left-32 w-80 h-80 rounded-full bg-[color:var(--color-teal)] opacity-15 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-6 pt-16 pb-20 md:pt-24 md:pb-28 grid gap-10 md:gap-14 md:grid-cols-12 items-center">
      <div class="md:col-span-6">
        <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-6 font-semibold">
          <span class="h-px w-8 bg-[color:var(--color-clay)]"></span>
          The independent guide to Houston
        </span>
        <h1 class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight text-balance">
          The city is <em class="italic font-normal text-[color:var(--color-clay)]">wider</em>, weirder, and <em class="italic font-normal text-[color:var(--color-teal)]">more fun</em> than you think.
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-[color:var(--color-ink-soft)] text-pretty">
          Tacos at 2 AM. Free museums. Rooftop bars. Brisket worth a flight. Murals on every block in Montrose. World Cup matches this summer. Start where you are — your neighborhood, your appetite, your day.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="/neighborhoods" class="inline-flex items-center gap-2 bg-[color:var(--color-clay)] text-[color:var(--color-paper)] px-7 py-4 text-sm font-semibold uppercase tracking-wider hover:bg-[color:var(--color-clay-dark)] transition-colors shadow-lg shadow-[color:var(--color-clay)]/30">
            Explore neighborhoods
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="/plan" class="inline-flex items-center gap-2 bg-[color:var(--color-teal)] text-[color:var(--color-paper)] px-7 py-4 text-sm font-semibold uppercase tracking-wider hover:bg-[color:var(--color-teal-deep)] transition-colors shadow-lg shadow-[color:var(--color-teal)]/30">
            Plan my trip ✨
          </a>
        </div>
      </div>

      <!-- Photo collage -->
      <div class="md:col-span-6">
        <div class="grid grid-cols-3 grid-rows-3 gap-3 h-[520px] md:h-[600px]">
          <figure class="col-span-2 row-span-2 relative overflow-hidden rounded-2xl shadow-2xl">
            <img src="https://images.unsplash.com/photo-1667754248024-e1e03e60eb72?w=900&q=80&auto=format&fit=crop" alt="Houston downtown skyline at dusk" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <figcaption class="absolute bottom-4 left-4 text-white text-sm font-[family-name:var(--font-display)] italic">Skyline at golden hour</figcaption>
          </figure>
          <figure class="relative overflow-hidden rounded-2xl shadow-lg">
            <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=400&q=80&auto=format&fit=crop" alt="Tacos on a plate" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
          </figure>
          <figure class="relative overflow-hidden rounded-2xl shadow-lg bg-[color:var(--color-clay)]">
            <img src="https://images.unsplash.com/photo-1607013251379-e6eecfffe234?w=400&q=80&auto=format&fit=crop" alt="Sliced brisket" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          </figure>
          <figure class="col-span-2 relative overflow-hidden rounded-2xl shadow-lg">
            <img src="https://images.unsplash.com/photo-1561214115-f2f134cc4912?w=800&q=80&auto=format&fit=crop" alt="Colorful murals in Montrose" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <figcaption class="absolute bottom-3 left-4 text-white text-xs font-semibold uppercase tracking-wider">Montrose murals</figcaption>
          </figure>
          <figure class="relative overflow-hidden rounded-2xl shadow-lg">
            <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=400&q=80&auto=format&fit=crop" alt="Cocktails at a Houston rooftop bar" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          </figure>
        </div>

        <!-- Floating stat callouts -->
        <div class="grid grid-cols-3 gap-3 mt-6">
          <div class="text-center px-3 py-3 bg-[color:var(--color-paper)] rounded-xl shadow border border-[color:var(--color-ink)]/5">
            <div class="font-[family-name:var(--font-display)] text-2xl text-[color:var(--color-clay)]">145+</div>
            <div class="text-[10px] uppercase tracking-wider text-[color:var(--color-ink-soft)]/70">Languages</div>
          </div>
          <div class="text-center px-3 py-3 bg-[color:var(--color-paper)] rounded-xl shadow border border-[color:var(--color-ink)]/5">
            <div class="font-[family-name:var(--font-display)] text-2xl text-[color:var(--color-teal)]">19</div>
            <div class="text-[10px] uppercase tracking-wider text-[color:var(--color-ink-soft)]/70">Museums</div>
          </div>
          <div class="text-center px-3 py-3 bg-[color:var(--color-paper)] rounded-xl shadow border border-[color:var(--color-ink)]/5">
            <div class="font-[family-name:var(--font-display)] text-2xl text-[color:var(--color-gold)]">7</div>
            <div class="text-[10px] uppercase tracking-wider text-[color:var(--color-ink-soft)]/70">World Cup matches</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VIBES GALLERY (color marquee) -->
  <section class="py-16 bg-[color:var(--color-cream-deep)] overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 mb-8">
      <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-3 font-semibold">A taste of Houston</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl tracking-tight text-balance">
        <em class="italic font-normal">Eight reasons</em> you'll keep coming back.
      </h2>
    </div>
    <div class="flex gap-4 overflow-x-auto pb-6 px-6 snap-x scroll-px-6">
      {vibeGallery.map((v) => (
        <figure class="flex-shrink-0 w-72 h-80 relative rounded-2xl overflow-hidden shadow-lg snap-start group">
          <img src={v.src} alt={v.caption} loading="lazy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <figcaption class="absolute bottom-5 left-5 right-5 text-white text-lg font-[family-name:var(--font-display)] italic leading-tight">{v.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- FEATURED NEIGHBORHOODS -->
  <section class="mx-auto max-w-7xl px-6 py-24">
    <div class="flex items-end justify-between mb-12 gap-6 flex-wrap">
      <div>
        <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-3 font-semibold">Start here</span>
        <h2 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl tracking-tight text-balance">
          Four neighborhoods, <br/><em class="italic font-normal text-[color:var(--color-teal)]">four very different Houstons.</em>
        </h2>
      </div>
      <a href="/neighborhoods" class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-clay)] hover:text-[color:var(--color-clay-dark)] transition-colors">All neighborhoods →</a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        featured.map((n, i) => {
          const accents = ["text-[color:var(--color-pink)]", "text-[color:var(--color-teal)]", "text-[color:var(--color-clay)]", "text-[color:var(--color-gold)]"];
          return (
            <a href={n.href} class="group block rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 bg-[color:var(--color-paper)]">
              <figure class="relative h-56 overflow-hidden">
                <img src={n.img} alt={`${n.name} Houston`} loading="lazy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
                <span class={`absolute top-4 left-4 text-[10px] uppercase tracking-[0.2em] font-bold text-white bg-black/40 backdrop-blur px-3 py-1 rounded-full`}>{n.tag}</span>
                <h3 class="absolute bottom-4 left-5 right-5 font-[family-name:var(--font-display)] text-3xl text-white drop-shadow-lg">{n.name}</h3>
              </figure>
              <div class="p-6">
                <p class="text-sm leading-relaxed text-[color:var(--color-ink-soft)]">{n.desc}</p>
                <span class={`mt-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.15em] ${accents[i]}`}>
                  Read the guide
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- SECTION BLOCKS with real photos -->
  <section class="mx-auto max-w-7xl px-6 py-12 space-y-24">
    {
      sections.map((s, i) => (
        <article class:list={["grid gap-10 md:gap-16 md:grid-cols-12 items-center", i % 2 === 1 && "md:[&>div:first-child]:order-2"]}>
          <div class="md:col-span-6">
            <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-4 font-semibold">{s.kicker}</span>
            <h2 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl tracking-tight mb-6 text-balance">
              {s.title}
            </h2>
            <p class="text-lg leading-relaxed text-[color:var(--color-ink-soft)] max-w-2xl mb-8 text-pretty">
              {s.body}
            </p>
            <a href={s.href} class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-6 py-3.5 text-sm font-semibold uppercase tracking-wider hover:bg-[color:var(--color-clay)] transition-colors rounded-full">
              {s.cta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="md:col-span-6">
            <figure class="aspect-[4/5] md:aspect-[5/6] rounded-3xl overflow-hidden shadow-2xl relative">
              <img src={s.img} alt={s.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
              <div class="absolute inset-0 ring-1 ring-inset ring-black/5"></div>
            </figure>
          </div>
        </article>
      ))
    }
  </section>

  <!-- WORLD CUP STRIP -->
  <section class="mx-auto max-w-7xl px-6 mt-24">
    <div class="bg-sunset text-white px-8 md:px-16 py-16 md:py-20 grid gap-8 md:grid-cols-12 items-center rounded-3xl shadow-2xl relative overflow-hidden">
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/10 blur-3xl"></div>
      <div class="md:col-span-8 relative">
        <span class="block text-xs uppercase tracking-[0.25em] text-white/90 mb-4 font-bold">Summer 2026</span>
        <h2 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl tracking-tight mb-4 text-balance">
          <em class="italic font-normal">¡Bienvenidos!</em> Welcome. <br/>The world is coming to Houston.
        </h2>
        <p class="text-base leading-relaxed text-white/90 max-w-2xl">
          NRG Stadium hosts seven matches between June 11 and July 19. We've put together a fan-first guide: where to stay near the stadium, which bars to pack into on match days, and how to actually get around without melting in July.
        </p>
      </div>
      <div class="md:col-span-4 md:text-right relative">
        <a href="/world-cup-2026" class="inline-flex items-center gap-2 bg-white text-[color:var(--color-clay-dark)] px-7 py-4 text-sm font-bold uppercase tracking-wider hover:bg-[color:var(--color-ink)] hover:text-white transition-colors rounded-full">
          World Cup guide
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ESSENTIALS PROMO -->
  <section class="mx-auto max-w-7xl px-6 py-20">
    <a href="/houston-essentials" class="block bg-[color:var(--color-paper)] border-2 border-[color:var(--color-teal)]/30 p-10 md:p-14 hover:bg-[color:var(--color-teal)]/5 hover:border-[color:var(--color-teal)] transition-colors group rounded-3xl">
      <div class="grid gap-8 md:grid-cols-12 items-center">
        <div class="md:col-span-8">
          <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-teal)] mb-3 font-semibold">Before you come</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl tracking-tight mb-4 group-hover:text-[color:var(--color-teal)] transition-colors text-balance">
            Books to read, gear to pack.
          </h2>
          <p class="text-[color:var(--color-ink-soft)] text-pretty">
            The short list of books that will change how you see Houston — plus the few things actually worth packing for the heat, humidity, and unexpected rain.
          </p>
        </div>
        <div class="md:col-span-4 md:text-right">
          <span class="inline-flex items-center gap-2 text-sm font-bold text-[color:var(--color-teal)] uppercase tracking-[0.15em]">
            Read the list
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- NEWSLETTER -->
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-4 font-semibold">The dispatch</span>
    <h2 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl tracking-tight mb-6 text-balance">
      One short email. <em class="italic font-normal text-[color:var(--color-teal)]">Once a month.</em>
    </h2>
    <p class="text-[color:var(--color-ink-soft)] mb-8 max-w-xl mx-auto text-pretty">
      New restaurant openings, neighborhood deep-dives, and the rare event worth crossing town for. No spam, no affiliate dump.
    </p>
    <form name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="newsletterForm">
      <input type="hidden" name="form-name" value="newsletter" />
      <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="flex-1 bg-[color:var(--color-paper)] border-2 border-[color:var(--color-ink)]/15 px-5 py-3 text-sm focus:outline-none focus:border-[color:var(--color-clay)] rounded-full"
      />
      <button
        type="submit"
        class="bg-[color:var(--color-clay)] text-[color:var(--color-paper)] px-7 py-3 text-sm font-bold uppercase tracking-wider hover:bg-[color:var(--color-clay-dark)] transition-colors rounded-full"
      >
        Subscribe
      </button>
    </form>
    <p id="newsletterSuccess" class="hidden mt-6 text-sm text-[color:var(--color-clay)] font-[family-name:var(--font-display)] italic">Thanks — we'll be in touch.</p>
    <script>
      document.getElementById('newsletterForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        try {
          await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(formData).toString()
          });
          form.style.display = 'none';
          document.getElementById('newsletterSuccess').classList.remove('hidden');
        } catch (err) {
          alert('Something went wrong. Please try again.');
        }
      });
    </script>
  </section>
</BaseLayout>
