---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact HtownGuide"
  description="Get in touch with HtownGuide — corrections, suggestions, partnership inquiries."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-24">
    <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-4">Contact</span>
    <h1 class="font-[family-name:var(--font-display)] text-5xl tracking-tight leading-tight mb-10 text-balance">
      Say hello.
    </h1>
    <p class="text-lg text-[color:var(--color-ink-soft)] mb-8 text-pretty">
      Spotted something wrong? Have a Houston spot we should know about? Partnership question? Email us — we read everything.
    </p>
    <a href="mailto:hello@htownguide.com" class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-6 py-3.5 text-sm font-medium hover:bg-[color:var(--color-clay)] transition-colors">
      hello@htownguide.com
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </section>
</BaseLayout>
