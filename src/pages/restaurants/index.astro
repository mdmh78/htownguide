---
import BaseLayout from "../../layouts/BaseLayout.astro";

const categories = [
  {
    title: "Tex-Mex & Mexican",
    desc: "The genre Houston arguably owns. Tex-Mex isn't Mexican food badly imitated — it's its own thing, born here.",
    picks: [
      { name: "Ninfa's on Navigation", address: "2704 Navigation Blvd", note: "The original location of the restaurant credited with inventing fajitas. Order them." },
      { name: "El Tiempo Cantina", address: "5602 Washington Ave", note: "Festive, family-style Tex-Mex. Multiple locations across the city." },
      { name: "Hugo's", address: "1600 Westheimer Rd", note: "Hugo Ortega's interior Mexican cuisine — moles, Oaxacan dishes, an obligatory weekend brunch." },
      { name: "Xochi", address: "1777 Walker St", note: "Hugo's Oaxacan flagship downtown. Get the mole tasting if it's available." },
    ],
  },
  {
    title: "Viet-Cajun & Crawfish",
    desc: "Houston has the third-largest Vietnamese population in the U.S., and Vietnamese cooks crashed crawfish boils with garlic, butter, and chiles. The result is one of the city's most distinct food traditions.",
    picks: [
      { name: "Crawfish & Noodles", address: "11360 Bellaire Blvd", note: "Trong Nguyen's Bellaire icon. The dish to order is exactly what the name says." },
      { name: "BB's Tex-Orleans", address: "2710 Montrose Blvd", note: "Crawfish boils with multiple seasoning blends. Bring napkins." },
      { name: "Cajun Kitchen", address: "5300 N Braeswood Blvd", note: "Boudin balls and étouffée done right. Strip-mall hidden gem in southwest Houston." },
    ],
  },
  {
    title: "Barbecue",
    desc: "Texas BBQ in Houston means brisket, and the city quietly has some of the best of it — without the Austin queues.",
    picks: [
      { name: "Truth BBQ", address: "110 S Heights Blvd", note: "Leonard Botello's brisket frequently ranks among the best in Texas. Pies are also serious." },
      { name: "Pinkerton's Barbecue", address: "1504 Airline Dr", note: "Heights smokehouse with technically masterful brisket and inventive sides." },
      { name: "Killen's Barbecue", address: "3613 E Broadway St, Pearland", note: "Ronnie Killen's Pearland temple of meat. Worth the drive south." },
      { name: "Goode Company Barbeque", address: "5109 Kirby Dr", note: "The classic. Been here since 1977. Get the jalapeño cheese bread." },
    ],
  },
  {
    title: "Fine dining & special occasion",
    desc: "Houston punches well above its national reputation here. James Beard winners scattered around the city.",
    picks: [
      { name: "Theodore Rex", address: "1302 Nance St", note: "Justin Yu's Heights restaurant. Modern, vegetable-forward, James Beard winner." },
      { name: "March", address: "1624 Westheimer Rd", note: "Mediterranean tasting menu, ambitious and refined. Splurge territory." },
      { name: "Bludorn", address: "807 Taft St", note: "Aaron Bludorn (formerly Cafe Boulud) brought New York polish to Montrose. Reliable for a celebration." },
      { name: "Nobie's", address: "2048 Colquitt St", note: "Inventive, hard to categorize, and consistently one of the best dining experiences in town." },
    ],
  },
  {
    title: "Casual and where locals actually go",
    desc: "The neighborhood spots that show up in our group texts.",
    picks: [
      { name: "Lucille's", address: "5512 La Branch St", note: "Soul food, Southern, on the edge of the Museum District. Don't skip the chicken." },
      { name: "Doris Metropolitan", address: "2815 S Shepherd Dr", note: "Israeli-style steakhouse. Counter-intuitive, excellent." },
      { name: "Coltivare", address: "3320 White Oak Dr", note: "Heights neighborhood Italian with a backyard garden. Pizza is the move." },
      { name: "Killen's STQ", address: "2231 S Voss Rd", note: "Casual Killen — burgers, brisket, pasta, all done at a higher level than they need to be." },
    ],
  },
];
---

<BaseLayout
  title="Where to Eat in Houston — Restaurants by Genre | HtownGuide"
  description="A real-Houstonian guide to eating in Houston: Tex-Mex, Viet-Cajun, BBQ, fine dining, and the casual neighborhood spots locals actually go to."
>
  <section class="relative">
    <figure class="relative h-[50vh] md:h-[60vh] overflow-hidden">
      <img src="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?w=1800&q=80&auto=format&fit=crop" alt="Mexican food spread" loading="eager" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 px-6 pb-12 md:pb-16">
        <div class="mx-auto max-w-7xl">
          <span class="inline-block text-xs uppercase tracking-[0.25em] text-[color:var(--color-gold)] mb-4 font-semibold bg-black/30 backdrop-blur px-3 py-1 rounded-full">Eat & drink</span>
          <h1 class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl md:text-7xl tracking-tight leading-[0.95] text-white drop-shadow-2xl">
            Where to <em class="italic font-normal text-[color:var(--color-gold)]">eat</em>.
          </h1>
        </div>
      </div>
    </figure>
  </section>

  <section class="mx-auto max-w-7xl px-6 pt-12 pb-8">
    <p class="max-w-2xl text-lg leading-relaxed text-[color:var(--color-ink-soft)] text-pretty">
      Houston is the most diverse big city in America, and the food scene reflects it. You can eat Tex-Mex, Viet-Cajun, Nigerian, Persian, and award-winning new-American — sometimes within the same strip mall. Below is how we'd send a visitor in.
    </p>
  </section>

  <!-- BBQ DEEP-DIVE PROMO -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <a href="/houston-bbq" class="block bg-[color:var(--color-ink)] text-[color:var(--color-paper)] p-10 md:p-14 hover:bg-[color:var(--color-clay)] transition-colors group">
      <div class="grid gap-8 md:grid-cols-12 items-center">
        <div class="md:col-span-9">
          <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-gold)] mb-3">Deep dive</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl tracking-tight mb-4 text-balance">
            <em class="italic font-normal">Houston BBQ, ranked.</em>
          </h2>
          <p class="text-[color:var(--color-paper)]/80 text-pretty">
            The 7 smokehouses worth your stomach space — Truth, Pinkerton's, The Pit Room, Killen's, and three old-school joints. Where to go, what to order, how to skip the line.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <span class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-gold)] uppercase tracking-[0.15em]">
            Read it
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-12 space-y-20">
    {
      categories.map((cat, i) => (
        <article>
          <div class="flex items-end gap-6 mb-8 flex-wrap">
            <span class="font-[family-name:var(--font-display)] text-6xl italic text-[color:var(--color-clay)]/40 leading-none">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="flex-1 min-w-[200px]">
              <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight mb-2">{cat.title}</h2>
              <p class="text-[color:var(--color-ink-soft)] max-w-2xl text-pretty">{cat.desc}</p>
            </div>
          </div>

          <div class="grid gap-px bg-[color:var(--color-ink)]/10 md:grid-cols-2">
            {
              cat.picks.map((p) => (
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(p.name + " " + p.address + " Houston")}`}
                  target="_blank"
                  rel="noopener"
                  class="block bg-[color:var(--color-cream)] p-6 md:p-8 hover:bg-[color:var(--color-paper)] transition-colors group"
                >
                  <h3 class="font-[family-name:var(--font-display)] text-2xl mb-2 group-hover:text-[color:var(--color-clay)] transition-colors">{p.name}</h3>
                  <p class="text-xs text-[color:var(--color-ink-soft)]/70 mb-3 uppercase tracking-[0.1em] flex items-center gap-1.5">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {p.address}
                    <span class="text-[color:var(--color-clay)] normal-case tracking-normal">· Maps →</span>
                  </p>
                  <p class="text-sm leading-relaxed text-[color:var(--color-ink-soft)]">{p.note}</p>
                </a>
              ))
            }
          </div>
        </article>
      ))
    }
  </section>

  <!-- COOKBOOK SHELF -->
  <section class="mx-auto max-w-3xl px-6 py-20">
    <span class="block text-xs uppercase tracking-[0.25em] text-[color:var(--color-clay)] mb-3">Take it home</span>
    <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight mb-3 text-balance">Cookbooks from Houston's best.</h2>
    <p class="text-base leading-relaxed text-[color:var(--color-ink-soft)] mb-10 text-pretty">
      Want to chase the Houston food scene at home? Start with the people who built it.
    </p>
    <div class="space-y-6">
      {[
        { title: "Hugo Ortega's Street Food of Mexico", author: "Hugo Ortega · Hugo's, Xochi", why: "Houston's Mexican food laureate translates his restaurant menus into a home kitchen. Mole, tamales, antojitos.", asin: "1419742183" },
        { title: "The Pho Cookbook: Easy to Adventurous Recipes for Vietnam's Favorite Soup and Noodles", author: "Andrea Nguyen", why: "Houston has the country's third-largest Vietnamese community. This is the book to understand the pho you're eating in Bellaire.", asin: "0399578331" },
        { title: "Tex-Mex: Traditions, Innovations, and Comfort Foods from Both Sides of the Border", author: "Ford Fry", why: "An honest, deeply-researched look at the genre Houston arguably invented. Recipes from a chef who gets it.", asin: "0399582312" },
      ].map((it) => (
        <a
          href={`https://www.amazon.com/dp/${it.asin}?tag=htownguide20-20`}
          target="_blank"
          rel="noopener nofollow sponsored"
          class="block bg-[color:var(--color-paper)] border border-[color:var(--color-ink)]/10 p-6 hover:bg-[color:var(--color-cream-deep)] transition-colors group"
        >
          <span class="block text-xs uppercase tracking-[0.18em] text-[color:var(--color-clay)] mb-2">{it.author}</span>
          <h3 class="font-[family-name:var(--font-display)] text-2xl mb-3 group-hover:text-[color:var(--color-clay)] transition-colors">{it.title}</h3>
          <p class="text-sm leading-relaxed text-[color:var(--color-ink-soft)]">{it.why}</p>
          <span class="mt-4 inline-flex items-center gap-2 text-xs font-medium text-[color:var(--color-clay)] uppercase tracking-[0.15em]">
            View on Amazon
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
